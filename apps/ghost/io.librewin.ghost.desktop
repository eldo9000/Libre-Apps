# Runtime OS packages: none (WebKitGTK bundled via Tauri)
[Desktop Entry]
Name=Ghost
Comment=Identity-randomizing browser — new fingerprint every session
Exec=env WEBKIT_DISABLE_DMABUF_RENDERER=1 ghost %U
Icon=io.librewin.ghost
Terminal=false
Type=Application
Categories=Network;WebBrowser;
Keywords=browser;web;private;ghost;internet;
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
