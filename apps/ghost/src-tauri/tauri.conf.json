{
  "productName": "Ghost",
  "version": "0.1.0",
  "identifier": "io.librewin.ghost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ghost",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": [
          "xdg-utils"
        ]
      },
      "rpm": {
        "depends": [
          "xdg-utils"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}