{
  "schema_version": 1,
  "id": "io.librewin.ghost",
  "name": "Ghost",
  "version": "0.1.0",
  "description": "Identity-randomizing browser — new fingerprint every session",
  "permissions": {
    "filesystem": {
      "read": true,
      "write": true,
      "scope": ["$DOWNLOADS"]
    },
    "network": {
      "outbound": true,
      "inbound": false
    },
    "subprocess": [],
    "webview": true,
    "notifications": false,
    "xattr": false
  },
  "runtime_deps": []
}
