# Runtime OS packages: libheif-freeworld (HEIC/HEIF decode)
# Note: binary installed as 'librewin-prism' to avoid name conflicts
[Desktop Entry]
Name=Prism
Comment=View images, video, audio, PDFs, and 3D models
Exec=env WEBKIT_DISABLE_DMABUF_RENDERER=1 librewin-prism %F
Icon=io.librewin.prism
Terminal=false
Type=Application
Categories=AudioVideo;Graphics;Viewer;
Keywords=viewer;media;image;video;audio;pdf;3d;prism;
MimeType=image/png;image/jpeg;image/gif;image/webp;image/svg+xml;image/bmp;image/avif;image/heic;image/heif;image/tiff;image/x-exr;image/x-portable-bitmap;video/mp4;video/webm;video/x-matroska;video/quicktime;video/x-msvideo;audio/mpeg;audio/ogg;audio/wav;audio/flac;audio/mp4;application/pdf;model/gltf+json;model/gltf-binary;
StartupNotify=true
