{
  "schema_version": 1,
  "id": "io.librewin.stack",
  "name": "Stack",
  "version": "0.1.0",
  "description": "Minimal markdown-first text editor",
  "permissions": {
    "filesystem": {
      "read": true,
      "write": true,
      "scope": ["$HOME"]
