# Runtime OS packages: none
# Note: binary installed as 'librewin-stack' to avoid name conflicts
[Desktop Entry]
Name=Stack
Comment=Minimal markdown-first text editor
Exec=env WEBKIT_DISABLE_DMABUF_RENDERER=1 librewin-stack %F
Icon=io.librewin.stack
Terminal=false
Type=Application
Categories=Utility;TextEditor;
Keywords=notes;markdown;text;editor;notepad;write;stack;
MimeType=text/markdown;text/x-markdown;text/plain;
StartupNotify=true
